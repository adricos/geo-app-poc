# Optional. Public URL path when the app is not served at domain root (sets Vite `base` / import.meta.env.BASE_URL). Example: /geo-app-poc/ — omit or leave empty for /
VITE_BASE=
VITE_MAP_STYLE_URL=
# Optional. Enables Cesium Ion imagery/terrain in the Cesium (3D) viewer. Get a token at https://ion.cesium.com/tokens
VITE_CESIUM_ION_ACCESS_TOKEN=
# Optional. ArcGIS API key for Cesium; removes the default-token warning when using ESRI/ArcGIS imagery. Get a key at https://developers.arcgis.com
VITE_ARCGIS_ACCESS_TOKEN=
# Required for the Mapbox (2D) viewer. Get a token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=
