    "globals": "^16.3.0",
    "jsdom": "^25.0.1",
    "knip": "^5.87.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
