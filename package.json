    "@tanstack/react-query": "^5.90.5",
    "@types/geojson": "^7946.0.16",
    "cesium": "^1.126.0",
    "mapbox-gl": "^3.8.0",
    "maplibre-gl": "^5.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-map-gl": "^8.1.0",
    "resium": "^1.19.4",
    "terra-draw": "^1.26.0",
    "terra-draw-mapbox-gl-adapter": "^1.3.0",
    "terra-draw-maplibre-gl-adapter": "^1.3.0",
